# =============================================================
# lkeff-listen — Windsurf AI Discord Bot
# Copy relevant vars to the root .env file.
# =============================================================

# Core
DISCORD_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
BOT_PREFIX=!

# Speech-to-Text
VOICE_ENABLED=true
STT_PROVIDER=whisper
STT_FALLBACK_PROVIDERS=whisper,deepspeech
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_AUTO_DETECT_LANGUAGE=true
WHISPER_STT_URL=http://whisper-stt:5000

# DeepSpeech
DEEPSPEECH_MODEL_PATH=/app/models/deepspeech/current/model.pbmm
DEEPSPEECH_SCORER_PATH=/app/models/deepspeech/current/scorer.scorer

# Voice Activity Detection
VAD_ENABLED=true
VAD_THRESHOLD=0.3
VAD_MIN_SPEECH_DURATION=0.2
VAD_MIN_SILENCE_DURATION=0.8
VAD_ADAPTIVE_THRESHOLD=true

# Text-to-Speech
TTS_ENABLED=true
TTS_PRIMARY_PROVIDER=azure
TTS_FALLBACK_PROVIDERS=azure,google
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
GOOGLE_TTS_CREDENTIALS_PATH=/app/credentials/google-tts.json
TTS_DEFAULT_SPEED=1.0
TTS_SPEED_MIN=0.5
TTS_SPEED_MAX=2.0
CROSSFADE_DURATION_MS=300
AUDIO_COMPRESSION_ENABLED=true

# Audio
AUDIO_QUALITY_PRESET=balanced
AUDIO_NOISE_REDUCTION_ENABLED=true
AUDIO_NORMALIZATION_ENABLED=true
AUDIO_MAX_PROCESSING_TIME=5.0
AUDIO_PARALLEL_PROCESSING=true
AUDIO_MAX_WORKERS=2

# Image Generation (DALL-E 3)
IMAGE_ENABLED=true
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_GENERATION_TIMEOUT=60.0
IMAGE_CACHE_ENABLED=true
IMAGE_CACHE_DIR=/app/data/image_cache
IMAGE_CACHE_MAX_SIZE_MB=500
IMAGE_MAX_RESOLUTION=1024x1024
IMAGE_QUALITY=standard
IMAGE_RATE_LIMIT_PER_USER=10
IMAGE_RATE_LIMIT_WINDOW_MINUTES=60

# Accessibility
ACCESSIBILITY_ENABLED=true
COLOR_BLINDNESS_SUPPORT=true
ALT_TEXT_GENERATION=true

# Library Standards / Code Audit
STANDARDS_ENABLED=true
STANDARDS_DEFAULT_PROFILE=python_pep8
STANDARDS_MAX_FILE_SIZE_MB=5
STANDARDS_MAX_FILES_PER_AUDIT=10
STANDARDS_RATE_LIMIT_PER_USER=5
STANDARDS_AI_MODEL=gpt-4o-mini

# Storage (replaces MongoDB)
REDIS_URL=redis://redis:6379
REDIS_TTL_SECONDS=86400
SQLITE_PATH=/app/data/bot.db
CONVERSATION_HISTORY_ENABLED=true
CONVERSATION_HISTORY_MAX_PER_USER=100
CONVERSATION_HISTORY_MAX_AGE_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
ERROR_TRACKING_ENABLED=true
LOG_MONITORING_ENABLED=true
LOG_PERFORMANCE_METRICS=true
STARTUP_VALIDATION_LEVEL=standard
HEALTH_CHECK_COMPREHENSIVE=true

# GPU (optional)
GPU_ENABLED=false
GPU_MEMORY_LIMIT_MB=2048
