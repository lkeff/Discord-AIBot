# =============================================================
# Discord-AIBot Unified Environment Configuration
# Copy to .env and fill in your values before starting.
# =============================================================

# ----------------------------
# Core
# ----------------------------
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-api03-...
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# ----------------------------
# Database — PostgreSQL (calm-discord-bot / Prisma)
# ----------------------------
DB_USER=botuser
DB_PASSWORD=your_secure_password
DB_NAME=calm_bot
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://botuser:your_secure_password@postgres:5432/calm_bot

# ----------------------------
# Database — Redis (cache / sessions / queues)
# ----------------------------
REDIS_URL=redis://redis:6379
REDIS_TTL_SECONDS=86400

# ----------------------------
# Database — SQLite (persistent user/conversation data)
# ----------------------------
SQLITE_PATH=/app/data/bot.db

# ----------------------------
# Discord MCP Server
# ----------------------------
MCP_PORT=4000

# ----------------------------
# Voice / Speech-to-Text
# ----------------------------
VOICE_ENABLED=true
STT_PROVIDER=whisper
STT_FALLBACK_PROVIDERS=whisper,deepspeech
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_AUTO_DETECT_LANGUAGE=true
WHISPER_STT_URL=http://whisper-stt:5000
DEEPSPEECH_MODEL_PATH=/app/models/deepspeech/current/model.pbmm
DEEPSPEECH_SCORER_PATH=/app/models/deepspeech/current/scorer.scorer

# Voice Activity Detection (VAD)
VAD_ENABLED=true
VAD_THRESHOLD=0.3
VAD_MIN_SPEECH_DURATION=0.2
VAD_MIN_SILENCE_DURATION=0.8
VAD_ADAPTIVE_THRESHOLD=true

# ----------------------------
# Text-to-Speech
# ----------------------------
TTS_ENABLED=true
TTS_PRIMARY_PROVIDER=azure
TTS_FALLBACK_PROVIDERS=azure,google
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
GOOGLE_TTS_CREDENTIALS_PATH=/app/credentials/google-tts.json
TTS_DEFAULT_SPEED=1.0
TTS_SPEED_MIN=0.5
TTS_SPEED_MAX=2.0
CROSSFADE_DURATION_MS=300
AUDIO_COMPRESSION_ENABLED=true

# ----------------------------
# Audio Processing
# ----------------------------
AUDIO_QUALITY_PRESET=balanced
AUDIO_NOISE_REDUCTION_ENABLED=true
AUDIO_NORMALIZATION_ENABLED=true
AUDIO_MAX_PROCESSING_TIME=5.0
AUDIO_PARALLEL_PROCESSING=true
AUDIO_MAX_WORKERS=2

# ----------------------------
# Image Generation (DALL-E)
# ----------------------------
IMAGE_ENABLED=true
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_GENERATION_TIMEOUT=60.0
IMAGE_CACHE_ENABLED=true
IMAGE_CACHE_DIR=/app/data/image_cache
IMAGE_CACHE_MAX_SIZE_MB=500
IMAGE_MAX_RESOLUTION=1024x1024
IMAGE_QUALITY=standard
IMAGE_RATE_LIMIT_PER_USER=10
IMAGE_RATE_LIMIT_WINDOW_MINUTES=60

# Accessibility
ACCESSIBILITY_ENABLED=true
COLOR_BLINDNESS_SUPPORT=true
ALT_TEXT_GENERATION=true

# ----------------------------
# Roblox Integration (calm-discord-bot)
# ----------------------------
ROBLOX_ENABLED=true
ROBLOX_API_KEY=Bearer_your_roblox_open_cloud_api_key
ROBLOX_UNIVERSE_ID=your_universe_id
ROBLOX_PLACE_ID=your_place_id
ROBLOX_WEBHOOK_SECRET=your_webhook_secret

# ----------------------------
# Feature Flags
# ----------------------------
ENABLE_ECONOMY=true
ENABLE_MODERATION=true
ENABLE_AIRHORN=true
ENABLE_ROBLOX=true
ENABLE_VOICE=true
ENABLE_IMAGE=true

# ----------------------------
# Logging & Monitoring
# ----------------------------
LOG_DIR=logs
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5
LOG_ENABLE_COMPRESSION=true
LOG_FILTER_SENSITIVE_DATA=true
ERROR_TRACKING_ENABLED=true
LOG_MONITORING_ENABLED=true
LOG_PERFORMANCE_METRICS=true
STARTUP_VALIDATION_LEVEL=standard
HEALTH_CHECK_COMPREHENSIVE=true

# ----------------------------
# Conversation History
# ----------------------------
CONVERSATION_HISTORY_ENABLED=true
CONVERSATION_HISTORY_MAX_PER_USER=100
CONVERSATION_HISTORY_MAX_AGE_DAYS=30

# ----------------------------
# GPU (optional)
# ----------------------------
GPU_ENABLED=false
GPU_MEMORY_LIMIT_MB=2048
