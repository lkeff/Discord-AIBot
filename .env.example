# Discord-AIBot Environment Configuration

# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=your_secure_password_here

# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token

# Optional: API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# Node Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Server Configuration
PORT=3000
API_PORT=8000

# Database
MONGODB_URI=mongodb://admin:password@mongodb:27017

# Feature Flags
ENABLE_AUDIO=true
ENABLE_VOICE=true
